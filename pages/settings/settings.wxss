.settings-page { padding: 16px; }

.section { margin-bottom: 20px; }
.section-title { font-size: 14px; color: #999; margin-bottom: 8px; padding-left: 4px; }

.stats-card { background: #fff; border-radius: 12px; padding: 16px; }
.stat-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f5f5f5; }
.stat-row:last-child { border-bottom: none; }
.stat-label { color: #666; font-size: 14px; }
.stat-value { color: #333; font-size: 14px; font-weight: 500; }

.action-list { background: #fff; border-radius: 12px; overflow: hidden; }
.action-item { display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; border-bottom: 1px solid #f5f5f5; }
.action-item:last-child { border-bottom: none; }
.action-text { font-size: 14px; color: #333; }
.action-text.danger { color: #FF4D4F; }
.arrow { font-size: 18px; color: #ccc; }

.footer { text-align: center; padding: 30px 0; }
.footer-text { font-size: 12px; color: #999; display: block; }
.footer-sub { font-size: 11px; color: #ddd; display: block; margin-top: 4px; }
