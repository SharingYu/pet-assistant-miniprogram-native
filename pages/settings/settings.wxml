<view class="settings-page">
  <view class="section">
    <view class="section-title">数据统计</view>
    <view class="stats-card">
      <view class="stat-row">
        <text class="stat-label">宠物数量</text>
        <text class="stat-value">{{petCount}} 只</text>
      </view>
      <view class="stat-row">
        <text class="stat-label">社区帖子</text>
        <text class="stat-value">{{postCount}} 条</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">操作</view>
    <view class="action-list">
      <view class="action-item" bindtap="clearData">
        <text class="action-text danger">清除所有数据</text>
        <text class="arrow">›</text>
      </view>
      <view class="action-item" bindtap="aboutApp">
        <text class="action-text">关于小程序</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">毛孩子健康助手 v{{version}}</text>
    <text class="footer-sub">您的宠物健康+社交管家</text>
  </view>
</view>
