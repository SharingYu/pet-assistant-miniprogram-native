.community-page { padding: 16px; }

.feed-tabs { display: flex; gap: 20px; margin-bottom: 16px; }
.feed-tabs .tab { font-size: 16px; color: #999; padding-bottom: 4px; }
.feed-tabs .tab.active { color: #FF9500; font-weight: 600; border-bottom: 2px solid #FF9500; }

.post-list { padding-bottom: 80px; }

.post-card { background: #fff; border-radius: 16px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }

.post-header { display: flex; align-items: center; margin-bottom: 12px; }
.post-avatar { font-size: 32px; margin-right: 10px; }
.post-user { flex: 1; }
.post-nickname { font-size: 14px; font-weight: 600; color: #333; }
.post-pet { font-size: 12px; color: #999; }
.post-time { font-size: 12px; color: #999; }

.post-content { font-size: 14px; color: #333; line-height: 1.6; margin-bottom: 12px; }

.post-images { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 12px; }
.post-img { width: 100px; height: 100px; border-radius: 8px; }

.post-actions { display: flex; gap: 20px; }
.action-item { display: flex; align-items: center; gap: 4px; font-size: 14px; color: #666; }

.fab {
  position: fixed;
  right: 20px;
  bottom: 100px;
  width: 56px;
  height: 56px;
  background: #FF9500;
  border-radius: 50%;
  color: #fff;
  font-size: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(255, 149, 0, 0.4);
}
