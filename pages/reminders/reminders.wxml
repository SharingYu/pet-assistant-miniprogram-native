<view class="reminders-page">
  <!-- 统计 -->
  <view class="stats">
    <view class="stat-item">
      <view class="stat-value">{{pendingCount}}</view>
      <view class="stat-label">待处理</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{doneCount}}</view>
      <view class="stat-label">已完成</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{petsCount}}</view>
      <view class="stat-label">宠物数</view>
    </view>
  </view>

  <!-- 提醒列表 -->
  <view class="reminder-list">
    <view class="reminder-group" wx:for="{{reminders}}" wx:if="{{!item.done}}" wx:key="id">
      <view class="reminder-item" bindtap="toggleDone" data-id="{{item.id}}">
        <view class="reminder-icon">{{getIcon(item.type)}}</view>
        <view class="reminder-info">
          <view class="reminder-title">{{item.title}}</view>
          <view class="reminder-meta">{{item.petName}} · {{formatDate(item.date)}}</view>
        </view>
        <view class="reminder-check">✓</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{reminders.length === 0 || pendingCount === 0}}">
    <view class="empty-icon">⏰</view>
    <view class="empty-title">暂无提醒</view>
    <view class="empty-desc">添加提醒，不错过毛孩子的健康护理</view>
  </view>

  <!-- 添加按钮 -->
  <view class="fab" bindtap="addReminder">+</view>
</view>
