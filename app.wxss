/* 全局样式 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  box-sizing: border-box;
  font-size: 14px;
  color: #333;
}

.card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  margin: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.btn-primary {
  background: #FF9500;
  color: #fff;
  border: none;
  border-radius: 24px;
  padding: 14px;
  text-align: center;
  font-size: 16px;
}

.btn-secondary {
  background: #fff;
  color: #FF9500;
  border: 2px solid #FF9500;
  border-radius: 24px;
  padding: 12px;
  text-align: center;
  font-size: 14px;
}

.btn-disabled {
  background: #ddd;
  color: #999;
  border: none;
  border-radius: 24px;
  padding: 14px;
  text-align: center;
  font-size: 16px;
}

.tag {
  display: inline-block;
  background: #FFF3E0;
  color: #FF9500;
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
  margin: 2px;
}

.fab {
  position: fixed;
  right: 20px;
  bottom: 100px;
  width: 56px;
  height: 56px;
  background: #FF9500;
  border-radius: 50%;
  color: #fff;
  font-size: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(255, 149, 0, 0.4);
}
